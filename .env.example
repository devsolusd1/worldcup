# Copy to .env and fill in. DO NOT commit .env.
# (For local dev only — production deploys read from real env vars.)

# Required: bs58-encoded secret key of the wallet that will pay for and own
# all 49 token deploys. Same format Phantom exports as "Private Key".
DEPLOYER_SECRET_KEY=

# Required for Pinata upload (npm run pinata)
PINATA_JWT=

# Optional: override RPC endpoint
# SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# Optional: folder containing the 49 *.CUP.json vanity keypair files
# Default: ./vanity-keys
# VANITY_DIR=C:\\Users\\John\\Downloads\\CUP

# Optional: Launchpad platform id (default: dog.fun platform from template)
# PLATFORM_ID=3swsaVK2YqNjnrTJR87KgbZXM5Vtko1Jt5ktdHqqGPR6
